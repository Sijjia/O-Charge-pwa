# API URL: пустая строка = proxy через Vercel rewrites / nginx / vite dev proxy
# Для прямого доступа к backend (без proxy) установите в .env.local:
# VITE_API_URL=https://ocpp.asystem.kg

# WebSocket — прямое соединение (proxy не поддерживает WS)
VITE_WEBSOCKET_URL=wss://ocpp.asystem.kg

# Supabase (self-hosted на sbobank.asystem.kg)
VITE_SUPABASE_URL=https://sbobank.asystem.kg
VITE_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjM2MzEyMCwiZXhwIjo0OTMyMDM2NzIwLCJyb2xlIjoiYW5vbiJ9.HWv8g298JpYqKaqPkVAsYJrYZMuFgnupw0ggDjng7zU

# 2GIS карта
VITE_2GIS_API_KEY=17896a11-2d90-4cd6-8698-37299195692e

# Demo Mode — для демонстрации заказчикам и локального тестирования
# Автоматически выключается при сборке для production (см .env.production)
VITE_DEMO_MODE=false

# Auth: enable cookie refresh (evp_access expires in 10min, evp_refresh in 7 days)
VITE_ENABLE_AUTH_REFRESH=true

# Keycloak SSO (staff/admin login)
VITE_KEYCLOAK_BASE_URL=https://sso.asystem.kg
VITE_KEYCLOAK_REALM=asystem
VITE_KEYCLOAK_CLIENT_ID=ocharge
VITE_SSO_ENABLED=false

# Dev Login — кнопки быстрого входа по ролям на /auth (для staging/демо)
# На реальном production выставить false или убрать
VITE_ALLOW_DEV_LOGIN=false
